BOT_TOKEN=your_bot_token_here
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/stubot?retryWrites=true&w=majority
WEB_URL=https://your-stubot-app.onrender.com
OWNER_ID=123456789
STORAGE_CHANNEL_ID=-1003296779450

# FORCE_JOIN_CHANNELS — gates the whole WebApp behind a "join these channels first"
# screen (this was already built into the Original Bot's frontend, just dormant
# because this var was empty). Leave this EMPTY unless you specifically want the
# whole mini-app locked behind Force Join. Comma-separated @usernames or -100... IDs.
FORCE_JOIN_CHANNELS=

# REFERRAL_FORCE_JOIN_CHANNELS — separate on purpose from FORCE_JOIN_CHANNELS above.
# This is what the per-batch Referral Unlock System uses to decide whether a
# referred user needs to join before their referral counts. Setting this does NOT
# turn on the WebApp-wide gate — only setting FORCE_JOIN_CHANNELS does that. If you
# want the same channels to apply to both, set both vars to the same value.
REFERRAL_FORCE_JOIN_CHANNELS=-1002553212331,-1003374353864

# NOTE: how many referrals unlock a batch is set PER BATCH by the admin (in the
# Create/Edit Batch form's "Referrals Required" field) — there is no global env
# var for it anymore. The unlock duration (7 days) is fixed in server.js as
# REFERRAL_PREMIUM_DURATION_MS if you ever need to change it.

# NOTE: the old UPI_ID / PAYMENT_GROUP_ID variables have been removed — the cash
# payment system was replaced by the free per-batch Referral Unlock System.
