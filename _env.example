# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/stubot?retryWrites=true&w=majority
WEB_URL=https://your-app.onrender.com
OWNER_ID=123456789

# ── File Storage Channel ──────────────────────────────────────────────────────
# A private channel where the bot is admin — used to store files safely
# If not set: files use direct file_id (not safe if you change the bot)
STORAGE_CHANNEL_ID=-1001234567890

# ── Force Join (comma-separated channel/group IDs or @usernames) ──────────────
# Leave empty to disable force join
# Example: FORCE_JOIN_CHANNELS=-1001234567890,-1009876543210
FORCE_JOIN_CHANNELS=

# Optional: display names and invite links for each force-join channel (in order)
# FORCE_JOIN_CHANNEL_NAMES=Study Group,Announcements
# FORCE_JOIN_CHANNEL_LINKS=https://t.me/+xxxxx,https://t.me/+yyyyy

# ── Premium Referral Config ───────────────────────────────────────────────────
# How many valid referrals needed to unlock 7-day premium (default: 5)
PREMIUM_REFERRAL_COUNT=5
# How many days premium lasts after unlock (default: 7)
PREMIUM_DAYS=7

# ── Daily Lecture Limit ───────────────────────────────────────────────────────
# Max lectures per user per day via bot (default: 10)
DAILY_VIDEO_LIMIT=10
